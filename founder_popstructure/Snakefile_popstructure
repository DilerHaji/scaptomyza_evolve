rule plot_admix_ksweep:
    input:
        admix    = expand("popstructure/pcangsd/founders_K{k}.admix.{k}.Q",
                          k=K_RANGE),
        metadata = "popstructure/metadata/founders.tsv",
    output:
        png = "popstructure/figures/founders_admix_ksweep.png",
        svg = "popstructure/figures/founders_admix_ksweep.svg",
    params:
        pairs = lambda wc, input: " ".join(
            f"{k}={p}" for k, p in zip(K_RANGE, input.admix)),
    log:
        "logs/popstructure/plot_admix_ksweep.log",
    conda:
        "envs/plotting_founders.yaml"
    shell:
        r"""
        python scripts/plot_admix_ksweep.py \
            --admix-files {params.pairs} \
            --metadata {input.metadata} \
            --output {output.png} \
            2> {log}
        """

rule plot_all192_pca:
    input:
        cov      = "popstructure/pcangsd/all192_K2.cov",
        metadata = "popstructure/metadata/all192.tsv",
    output:
        png = "popstructure/figures/all192_pca_founders_vs_t2g07.png",
        svg = "popstructure/figures/all192_pca_founders_vs_t2g07.svg",
    log:
        "logs/popstructure/plot_all192_pca.log",
    conda:
        "envs/plotting_founders.yaml"
    shell:
        r"""
        python scripts/plot_popstructure_pca.py \
            --cov {input.cov} \
            --metadata {input.metadata} \
            --color-by pool_type \
            --output {output.png} \
            2> {log}
        """

rule verify_popstructure:
    input:
        covs    = expand("popstructure/pcangsd/founders_K{k}.cov",       k=K_RANGE),
        admix   = expand("popstructure/pcangsd/founders_K{k}.admix.{k}.Q", k=K_RANGE),
        metadata = "popstructure/metadata/founders.tsv",
        bamlist  = FOUNDERS_BAMLIST,
    output:
        report = "popstructure/qc/verify_report.txt",
    params:
        pcangsd_dir = "popstructure/pcangsd",
        logs_dir    = "logs/popstructure",
    log:
        "logs/popstructure/verify.log",
    conda:
        "envs/plotting_founders.yaml"
    shell:
        r"""
        mkdir -p popstructure/qc
        python scripts/verify_popstructure.py \
            --pcangsd-dir {params.pcangsd_dir} \
            --logs-dir    {params.logs_dir} \
            --metadata    {input.metadata} \
            --bamlist     {input.bamlist} \
            --output      {output.report} \
            > {log} 2>&1
        """


rule summarize_admix_by_source:
    input:
        admix    = "popstructure/pcangsd/founders_K{k}.admix.{k}.Q",
        metadata = "popstructure/metadata/founders.tsv",
    output:
        by_host = "popstructure/tables/founders_K{k}_by_host.tsv",
    params:
        prefix = "popstructure/tables/founders_K{k}",
    log:
        "logs/popstructure/summarize_K{k}.log",
    conda:
        "envs/plotting_founders.yaml"
    shell:
        r"""
        mkdir -p popstructure/tables
        python scripts/summarize_admix_by_source.py \
            --admix {input.admix} \
            --metadata {input.metadata} \
            --output-prefix {params.prefix} \
            > {log} 2>&1
        """
